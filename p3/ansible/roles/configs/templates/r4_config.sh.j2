#!/bin/bash

ip link add br10 type bridge
ip link set br10 up

ip link add vxlan10 type vxlan \
 id 10 \
 local {{ r4_id }} \
 dstport 4789 \
 nolearning

ip link set vxlan10 up

ip link set eth1 master br10
ip link set vxlan10 master br10


ip addr add {{ r4_lo0 }} dev lo

ip addr add {{ r1_r4_rr_net }}2/30 dev eth0

ip link set lo up
ip link set eth0 up

vtysh << EOF

configure terminal

##### OSPF CONFIGURATION ######

router ospf
 ospf router-id {{ r4_id }}
 passive-interface lo

interface lo
 ip ospf area 0

interface eth0
 ip ospf area 0

###### BGP CONFIGURATION ######

router bgp 65000
 bgp router-id {{ r4_id }}

 neighbor {{ r1_id }} remote-as 65000
 neighbor {{ r1_id }} update-source lo

 address-family l2vpn evpn

  neighbor {{ r1_id }} activate
  advertise-all-vni

 exit-address-family

 
end
write memory

EOF