#!/bin/bash

ip addr add {{ r2_lo0 }} dev lo

ip addr add {{ r1_r2_rr_net }}2/30 dev eth0

ip link set lo up
ip link set eth0 up

vtysh << EOF

configure terminal

router ospf
 ospf router-id 2.2.2.2
 passive-interface lo

interface lo
 ip ospf area 0

interface eth0
 ip ospf area 0

end
write memory

EOF