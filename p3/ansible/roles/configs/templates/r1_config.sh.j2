#!/bin/bash

ip addr add {{ r1_lo0 }} dev lo

ip addr add {{ r1_r2_rr_net }}1/30 dev eth0
ip addr add {{ r1_r3_rr_net }}1/30 dev eth1
ip addr add {{ r1_r4_rr_net }}1/30 dev eth2

ip link set lo up
ip link set eth0 up
ip link set eth1 up
ip link set eth2 up

vtysh << EOF

configure terminal

router ospf
 ospf router-id 1.1.1.1
 passive-interface lo

interface lo
 ip ospf area 0

interface eth0
 ip ospf area 0

interface eth1
 ip ospf area 0

interface eth2
 ip ospf area 0

end
write memory

EOF